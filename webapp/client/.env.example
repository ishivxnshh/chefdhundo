# Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# Mobile OTP Authentication (TextBee + Custom Session)
TEXTBEE_API_KEY=your-textbee-api-key
TEXTBEE_DEVICE_ID=your-textbee-device-id
OTP_SECRET=replace-with-a-long-random-secret
AUTH_SECRET=replace-with-a-long-random-secret
WHATSAPP_INGEST_SECRET=replace-with-a-long-random-secret

# Cashfree Payment Gateway
CASHFREE_CLIENT_ID=your-cashfree-client-id
CASHFREE_CLIENT_SECRET=your-cashfree-client-secret
CASHFREE_ENV=sandbox # or 'production' for live
NEXT_PUBLIC_CASHFREE_ENV=sandbox # or 'production' for live
NEXT_PUBLIC_APP_URL=http://localhost:3000 # Change to your production URL

# Supabase Database
SUPABASE_PROJECT_NAME=your-project-name
SUPABASE_DATABASE_PASSWORD=your-database-password
SUPABASE_PROJECT_URL=your-supabase-project-url
SUPABASE_PUBLIC_ANON_KEY=your-supabase-publishable-or-anon-key
SUPABASE_SERVICE_ROLE=your-supabase-secret-or-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# RazorPay Payment Gateway
NEXT_PUBLIC_RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
